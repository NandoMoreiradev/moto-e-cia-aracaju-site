generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Moto {
  id             String       @id @default(cuid())
  slug           String       @unique
  nome           String
  marca          MarcaMoto
  tipo           TipoMoto
  preco          Decimal?     @db.Decimal(10, 2)
  precoFormatado String?
  descricao      String
  specs          Json         @default("{}")
  destaque       Boolean      @default(false)
  status         StatusMoto   @default(DISPONIVEL)
  metaProductId  String?
  ano            Int?
  km             Int?
  cor            String?
  vin            String?
  combustivel    Combustivel  @default(GASOLINA)
  transmissao    Transmissao  @default(MANUAL)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  capaR2Key      String?
  capaUrl        String?
  logoR2Key      String?
  logoUrl        String?
  slogan         String?
  diferenciais   String?
  condicao       CondicaoMoto @default(NOVA)
  fotos          MotoFoto[]

  @@map("motos")
}

model MotoFoto {
  id              String  @id @default(cuid())
  url             String
  r2Key           String
  principal       Boolean @default(false)
  ordem           Int     @default(0)
  motoId          String
  corHex          String?
  corNome         String?
  exibirNoSeletor Boolean @default(true)
  exibirNaGaleria Boolean @default(true)
  moto            Moto    @relation(fields: [motoId], references: [id], onDelete: Cascade)

  @@map("moto_fotos")
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  titulo      String
  resumo      String
  conteudo    Json      @default("{}")
  coverUrl    String?
  coverR2Key  String?
  tags        String[]
  publicado   Boolean   @default(false)
  publicadoEm DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_posts")
}

model Lead {
  id            String   @id @default(cuid())
  nome          String
  email         String
  whatsapp      String?
  mensagem      String
  motoInteresse String?
  lido          Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@map("leads")
}

model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("site_configs")
}

model Banner {
  id               String   @id @default(cuid())
  label            String?
  titulo           String?
  subtitulo        String?
  imageUrl         String
  imageR2Key       String
  link             String?
  ordem            Int      @default(0)
  ativo            Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  mobileImageUrl   String?
  mobileImageR2Key String?

  @@map("banners")
}

model Marca {
  id        String   @id @default(cuid())
  nome      String   @unique
  logoUrl   String
  logoR2Key String
  ordem     Int      @default(0)
  ativa     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("marcas")
}

enum Role {
  ADMIN
  EDITOR
}

enum MarcaMoto {
  SUZUKI
  HAOJUE
  ZONTES
  KYMCO
  OUTRO
}

enum CondicaoMoto {
  NOVA
  SEMINOVA
}

enum TipoMoto {
  SPORT
  NAKED
  ADVENTURE
  SCOOTER
  TRAIL
  STREET
  CROSSOVER
  CUSTOM
  TOURING
}

enum StatusMoto {
  DISPONIVEL
  VENDIDA
  RESERVADA
  ALUGUEL
}

enum Combustivel {
  GASOLINA
  ETANOL
  FLEX
  ELETRICO
}

enum Transmissao {
  MANUAL
  AUTOMATICA
  SEMI_AUTOMATICA
}
