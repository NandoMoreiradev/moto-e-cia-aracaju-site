// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Seed: npx ts-node --project ../../prisma/tsconfig.json ../../prisma/seed.ts
// (executar a partir de apps/api/)

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// USERS & AUTH
// ==========================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  ADMIN
  EDITOR
}

// ==========================================
// MOTOS
// ==========================================

model Moto {
  id             String     @id @default(cuid())
  slug           String     @unique
  nome           String
  marca          MarcaMoto
  tipo           TipoMoto
  preco          Decimal?   @db.Decimal(10, 2)
  precoFormatado String?
  descricao      String     @db.Text
  specs          Json       @default("{}")
  destaque       Boolean    @default(false)
  status         StatusMoto @default(DISPONIVEL)
  metaProductId  String?    // ID do produto sincronizado com Meta Commerce

  // Imagem de Capa (Hero Banner)
  capaUrl        String?
  capaR2Key      String?

  // Campos obrigatórios Meta Vehicle Catalog (Graph API v25.0)
  ano           Int?        // Ano de fabricação
  km            Int?        // Quilometragem (0 = zero km)
  cor           String?     // Cor principal
  vin           String?     // Número de chassi / VIN (opcional mas recomendado)
  combustivel   Combustivel @default(GASOLINA)
  transmissao   Transmissao @default(MANUAL)

  fotos MotoFoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("motos")
}

model MotoFoto {
  id        String  @id @default(cuid())
  url       String  // URL pública do Cloudflare R2
  r2Key     String  // Chave do objeto no bucket R2
  principal Boolean @default(false)
  ordem     Int     @default(0)
  corHex    String? // Código Hexadecimal para o dot de seleção
  corNome   String? // Nome da cor (ex: Vermelho Candy)

  motoId String
  moto   Moto   @relation(fields: [motoId], references: [id], onDelete: Cascade)

  @@map("moto_fotos")
}

enum MarcaMoto {
  SUZUKI
  HAOJUE
  ZONTES
  KYMCO
  OUTRO
  SEMINOVA
}

enum TipoMoto {
  SPORT
  NAKED
  ADVENTURE
  SCOOTER
  TRAIL
}

enum StatusMoto {
  DISPONIVEL
  VENDIDA
  RESERVADA
  ALUGUEL
}

enum Combustivel {
  GASOLINA
  ETANOL
  FLEX
  ELETRICO
}

enum Transmissao {
  MANUAL
  AUTOMATICA
  SEMI_AUTOMATICA
}

// ==========================================
// BLOG
// ==========================================

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  titulo      String
  resumo      String    @db.Text
  conteudo    Json      @default("{}") // TipTap JSON
  coverUrl    String?   // URL pública do Cloudflare R2
  coverR2Key  String?   // Chave do objeto no bucket R2
  tags        String[]
  publicado   Boolean   @default(false)
  publicadoEm DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blog_posts")
}

// ==========================================
// LEADS / CONTATO
// ==========================================

model Lead {
  id             String  @id @default(cuid())
  nome           String
  email          String
  whatsapp       String?
  mensagem       String  @db.Text
  motoInteresse  String? // slug da moto de interesse
  lido           Boolean @default(false)

  createdAt DateTime @default(now())

  @@map("leads")
}

// ==========================================
// CONFIGURAÇÕES DO SITE
// ==========================================

model SiteConfig {
  id    String @id @default(cuid())
  key   String @unique
  value Json

  updatedAt DateTime @updatedAt

  @@map("site_configs")
}
